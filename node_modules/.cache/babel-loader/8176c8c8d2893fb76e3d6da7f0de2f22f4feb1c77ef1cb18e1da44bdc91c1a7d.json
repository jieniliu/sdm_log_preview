{"ast":null,"code":"import api from '../services/api';\nexport default {\n  name: 'LogDataView',\n  data() {\n    return {\n      filters: {\n        startTime: Date.now() - 7 * 24 * 60 * 60 * 1000,\n        // 默认7天前\n        endTime: Date.now(),\n        messageType: '',\n        userId: ''\n      },\n      logData: {\n        action_type_count: {\n          socket_disconnected_count: 0,\n          launch_count: 0,\n          enter_room_count: 0,\n          send_message_count: 0,\n          send_success_count: 0,\n          send_fail_count: 0\n        },\n        avg_socket_time: {\n          average_response_time: 0\n        },\n        user_count: 0,\n        message_send_avg_time: 0,\n        send_to_sync_avg: 0\n      }\n    };\n  },\n  computed: {\n    actionTypeData() {\n      return [{\n        name: '启动次数',\n        value: this.logData.action_type_count?.launch_count || 0,\n        key: 'launch_count'\n      }, {\n        name: 'socket断开次数',\n        value: this.logData.action_type_count?.socket_disconnected_count || 0,\n        key: 'socket_disconnected_count'\n      }, {\n        name: '进入房间次数',\n        value: this.logData.action_type_count?.enter_room_count || 0,\n        key: 'enter_room_count'\n      }, {\n        name: '发消息次数',\n        value: this.logData.action_type_count?.send_message_count || 0,\n        key: 'send_message_count'\n      }, {\n        name: '消息发送成功次数',\n        value: this.logData.action_type_count?.send_success_count || 0,\n        key: 'send_success_count'\n      }, {\n        name: '消息发送失败次数',\n        value: this.logData.action_type_count?.send_fail_count || 0,\n        key: 'send_fail_count'\n      }];\n    },\n    timeData() {\n      return [{\n        name: 'socket链接时长',\n        value: this.logData.avg_socket_time?.average_response_time || 0,\n        key: 'avg_socket_time'\n      }, {\n        name: '发消息耗时',\n        value: this.logData.message_send_avg_time || 0,\n        key: 'avg_sendmessage_time'\n      }, {\n        name: 'sync回消息耗时',\n        value: this.logData.send_to_sync_avg || 0,\n        key: 'send_to_sync'\n      }];\n    }\n  },\n  mounted() {\n    this.fetchData();\n  },\n  methods: {\n    async fetchData() {\n      try {\n        const response = await api.getLogSummary(this.filters.startTime, this.filters.endTime, this.filters.messageType, this.filters.userId);\n        this.logData = response.data;\n      } catch (error) {\n        console.error('获取日志数据失败:', error);\n        this.$message.error('获取数据失败，请稍后重试');\n      }\n    },\n    highlightSocketRow({\n      row\n    }) {\n      if (row.key === 'socket_disconnected_count') {\n        return 'highlighted-row';\n      }\n      return '';\n    },\n    highlightSendMessageRow({\n      row\n    }) {\n      if (row.key === 'avg_sendmessage_time') {\n        return 'highlighted-row';\n      }\n      return '';\n    },\n    highlightActionRows({\n      row\n    }) {\n      if (row.key === 'send_message_count' || row.key === 'send_fail_count') {\n        return 'highlighted-row';\n      }\n      return '';\n    },\n    highlightTimeRows({\n      row\n    }) {\n      if (row.key === 'avg_sendmessage_time') {\n        return 'highlighted-row';\n      }\n      return '';\n    }\n  }\n};","map":{"version":3,"names":["api","name","data","filters","startTime","Date","now","endTime","messageType","userId","logData","action_type_count","socket_disconnected_count","launch_count","enter_room_count","send_message_count","send_success_count","send_fail_count","avg_socket_time","average_response_time","user_count","message_send_avg_time","send_to_sync_avg","computed","actionTypeData","value","key","timeData","mounted","fetchData","methods","response","getLogSummary","error","console","$message","highlightSocketRow","row","highlightSendMessageRow","highlightActionRows","highlightTimeRows"],"sources":["/Users/apple/ai_completion/trace/src/views/LogDataView.vue"],"sourcesContent":["<template>\n  <div class=\"log-data-container\">\n    <h1 class=\"page-title\">日志数据中心</h1>\n    \n    <el-card class=\"filter-card\">\n      <div class=\"filter-container\">\n        <div class=\"filter-group\">\n          <div class=\"filter-item\">\n            <span class=\"filter-label\">开始时间：</span>\n            <el-date-picker\n              v-model=\"filters.startTime\"\n              type=\"datetime\"\n              placeholder=\"选择开始时间\"\n              format=\"YYYY-MM-DD HH:mm:ss\"\n              value-format=\"x\"\n              size=\"small\"\n              class=\"custom-date-picker dark-date-input\"\n              :popper-class=\"'dark-date-picker'\"\n            />\n          </div>\n          \n          <div class=\"filter-item\">\n            <span class=\"filter-label\">结束时间：</span>\n            <el-date-picker\n              v-model=\"filters.endTime\"\n              type=\"datetime\"\n              placeholder=\"选择结束时间\"\n              format=\"YYYY-MM-DD HH:mm:ss\"\n              value-format=\"x\"\n              size=\"small\"\n              class=\"custom-date-picker dark-date-input\"\n              :popper-class=\"'dark-date-picker'\"\n            />\n          </div>\n        </div>\n        \n        <div class=\"filter-group\">\n          <div class=\"filter-item\">\n            <span class=\"filter-label\">消息类型：</span>\n            <el-select\n              v-model=\"filters.messageType\"\n              placeholder=\"请选择消息类型\"\n              clearable\n              size=\"small\"\n              popper-class=\"dark-select-dropdown\"\n              class=\"dark-select\"\n            >\n              <el-option label=\"文本消息\" value=\"m.text\" />\n              <el-option label=\"图片消息\" value=\"m.image\" />\n              <el-option label=\"视频消息\" value=\"m.video\" />\n              <el-option label=\"语音消息\" value=\"m.voice\" />\n              <el-option label=\"文件消息\" value=\"m.file\" />\n            </el-select>\n          </div>\n          \n          <div class=\"filter-item\">\n            <span class=\"filter-label\">用户ID：</span>\n            <el-input\n              v-model=\"filters.userId\"\n              placeholder=\"请输入用户ID\"\n              clearable\n              size=\"small\"\n              class=\"dark-input\"\n            />\n          </div>\n          \n          <el-button type=\"primary\" @click=\"fetchData\" size=\"small\">查询</el-button>\n        </div>\n      </div>\n    </el-card>\n    \n    <div class=\"data-display-section\">\n      <!-- 核心指标卡片 -->\n      <el-row :gutter=\"20\">\n        <el-col :xs=\"24\" :sm=\"8\" :md=\"8\" :lg=\"8\" :xl=\"8\">\n          <el-card class=\"metric-card\">\n            <div class=\"metric-value\">{{ logData.user_count || 0 }}</div>\n            <div class=\"metric-title\">用户数量</div>\n          </el-card>\n        </el-col>\n        \n        <el-col :xs=\"24\" :sm=\"8\" :md=\"8\" :lg=\"8\" :xl=\"8\">\n          <el-card class=\"metric-card\">\n            <div class=\"metric-value\">{{ logData.message_send_avg_time || 0 }}</div>\n            <div class=\"metric-title\">消息发送耗时 (ms)</div>\n          </el-card>\n        </el-col>\n        \n        <el-col :xs=\"24\" :sm=\"8\" :md=\"8\" :lg=\"8\" :xl=\"8\">\n          <el-card class=\"metric-card\">\n            <div class=\"metric-value\">{{ logData.avg_socket_time?.average_response_time || 0 }}</div>\n            <div class=\"metric-title\">Socket响应时间 (ms)</div>\n          </el-card>\n        </el-col>\n      </el-row>\n      \n      <!-- 表格区域 -->\n      <el-row :gutter=\"20\">\n        <el-col :xs=\"24\" :sm=\"24\" :md=\"12\" :lg=\"12\" :xl=\"12\">\n          <el-card class=\"table-card custom-table-card\">\n            <template #header>\n              <div class=\"card-header\">\n                <h3>操作统计</h3>\n              </div>\n            </template>\n            <div class=\"table-wrapper\">\n              <el-table \n                :data=\"actionTypeData\" \n                size=\"small\" \n                stripe \n                style=\"width: 100%\"\n                highlight-current-row\n                :row-class-name=\"highlightActionRows\"\n                row-key=\"key\"\n                class=\"dark-table custom-border-table no-header-line\"\n                header-row-class-name=\"table-header-row\"\n              >\n                <el-table-column prop=\"name\" label=\"事件\" min-width=\"120\" />\n                <el-table-column prop=\"value\" label=\"数值\" width=\"100\" align=\"right\" />\n                <el-table-column prop=\"key\" label=\"字段\" min-width=\"140\" class-name=\"field-column\" />\n              </el-table>\n            </div>\n          </el-card>\n        </el-col>\n        \n        <el-col :xs=\"24\" :sm=\"24\" :md=\"12\" :lg=\"12\" :xl=\"12\">\n          <el-card class=\"table-card custom-table-card\">\n            <template #header>\n              <div class=\"card-header\">\n                <h3>耗时统计</h3>\n              </div>\n            </template>\n            <div class=\"table-wrapper\">\n              <el-table \n                :data=\"timeData\" \n                size=\"small\" \n                stripe \n                style=\"width: 100%\" \n                highlight-current-row\n                :row-class-name=\"highlightTimeRows\"\n                row-key=\"key\"\n                class=\"dark-table custom-border-table no-header-line\"\n                header-row-class-name=\"table-header-row\"\n              >\n                <el-table-column prop=\"name\" label=\"事件\" min-width=\"120\" />\n                <el-table-column prop=\"value\" label=\"数值 (ms)\" width=\"100\" align=\"right\" />\n                <el-table-column prop=\"key\" label=\"字段\" min-width=\"140\" class-name=\"field-column\" />\n              </el-table>\n            </div>\n          </el-card>\n        </el-col>\n      </el-row>\n    </div>\n  </div>\n</template>\n\n<script>\nimport api from '../services/api'\n\nexport default {\n  name: 'LogDataView',\n  data() {\n    return {\n      filters: {\n        startTime: Date.now() - 7 * 24 * 60 * 60 * 1000, // 默认7天前\n        endTime: Date.now(),\n        messageType: '',\n        userId: ''\n      },\n      logData: {\n        action_type_count: {\n          socket_disconnected_count: 0,\n          launch_count: 0,\n          enter_room_count: 0,\n          send_message_count: 0,\n          send_success_count: 0,\n          send_fail_count: 0\n        },\n        avg_socket_time: {\n          average_response_time: 0\n        },\n        user_count: 0,\n        message_send_avg_time: 0,\n        send_to_sync_avg: 0\n      }\n    }\n  },\n  computed: {\n    actionTypeData() {\n      return [\n        { name: '启动次数', value: this.logData.action_type_count?.launch_count || 0, key: 'launch_count' },\n        { name: 'socket断开次数', value: this.logData.action_type_count?.socket_disconnected_count || 0, key: 'socket_disconnected_count' },\n        { name: '进入房间次数', value: this.logData.action_type_count?.enter_room_count || 0, key: 'enter_room_count' },\n        { name: '发消息次数', value: this.logData.action_type_count?.send_message_count || 0, key: 'send_message_count' },\n        { name: '消息发送成功次数', value: this.logData.action_type_count?.send_success_count || 0, key: 'send_success_count' },\n        { name: '消息发送失败次数', value: this.logData.action_type_count?.send_fail_count || 0, key: 'send_fail_count' }\n      ]\n    },\n    timeData() {\n      return [\n        { name: 'socket链接时长', value: this.logData.avg_socket_time?.average_response_time || 0, key: 'avg_socket_time' },\n        { name: '发消息耗时', value: this.logData.message_send_avg_time || 0, key: 'avg_sendmessage_time' },\n        { name: 'sync回消息耗时', value: this.logData.send_to_sync_avg || 0, key: 'send_to_sync' }\n      ]\n    }\n  },\n  mounted() {\n    this.fetchData()\n  },\n  methods: {\n    async fetchData() {\n      try {\n        const response = await api.getLogSummary(\n          this.filters.startTime,\n          this.filters.endTime,\n          this.filters.messageType,\n          this.filters.userId\n        )\n        this.logData = response.data\n      } catch (error) {\n        console.error('获取日志数据失败:', error)\n        this.$message.error('获取数据失败，请稍后重试')\n      }\n    },\n    highlightSocketRow({ row }) {\n      if (row.key === 'socket_disconnected_count') {\n        return 'highlighted-row'\n      }\n      return ''\n    },\n    highlightSendMessageRow({ row }) {\n      if (row.key === 'avg_sendmessage_time') {\n        return 'highlighted-row'\n      }\n      return ''\n    },\n    highlightActionRows({ row }) {\n      if (row.key === 'send_message_count' || row.key === 'send_fail_count') {\n        return 'highlighted-row'\n      }\n      return ''\n    },\n    highlightTimeRows({ row }) {\n      if (row.key === 'avg_sendmessage_time') {\n        return 'highlighted-row'\n      }\n      return ''\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.log-data-container {\n  padding: 16px;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.page-title {\n  color: var(--text-color);\n  margin-bottom: 16px;\n  text-align: center;\n  font-size: 1.5rem;\n  font-weight: 500;\n}\n\n.filter-card {\n  margin-bottom: 16px;\n  border-left: 3px solid var(--secondary-color);\n}\n\n.filter-container {\n  display: flex;\n  justify-content: space-between;\n  gap: 12px;\n  \n  @media (max-width: 768px) {\n    flex-direction: column;\n  }\n}\n\n.filter-group {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  align-items: center;\n}\n\n.filter-item {\n  display: flex;\n  align-items: center;\n}\n\n.filter-label {\n  margin-right: 6px;\n  white-space: nowrap;\n  font-size: 14px;\n  color: var(--text-secondary);\n}\n\n.data-display-section {\n  margin-top: 16px;\n}\n\n.metric-card {\n  margin-bottom: 16px;\n  text-align: center;\n  padding: 10px;\n  height: auto;\n  border-top: 3px solid var(--secondary-color);\n  \n  .metric-value {\n    font-size: 28px;\n    font-weight: bold;\n    color: var(--highlight-color);\n    margin-bottom: 6px;\n  }\n  \n  .metric-title {\n    font-size: 14px;\n    color: var(--text-secondary);\n  }\n}\n\n.table-card {\n  margin-bottom: 16px;\n  \n  :deep(.field-column .cell) {\n    color: var(--text-secondary);\n    font-family: 'Courier New', monospace;\n    font-size: 12px;\n  }\n}\n\n.custom-table-card {\n  :deep(.el-card__header) {\n    border-bottom: 1px solid var(--divider-color) !important;\n  }\n\n  :deep(.el-card__body) {\n    padding: 0 !important;\n  }\n}\n\n.table-wrapper {\n  position: relative;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  \n  h3 {\n    margin: 0;\n    color: var(--text-color);\n    font-size: 16px;\n    font-weight: 500;\n  }\n}\n\n:deep(.custom-date-picker) {\n  .el-input__inner {\n    background-color: var(--date-input-bg) !important;\n    color: var(--text-color) !important;\n    border-color: var(--border-color) !important;\n  }\n}\n\n:deep(.dark-table) {\n  background-color: var(--background-card) !important;\n  \n  thead th {\n    background-color: var(--background-card) !important;\n    border-bottom: 1px solid var(--table-header-border) !important;\n  }\n  \n  tr.el-table__row td {\n    background-color: var(--background-stripe-odd) !important;\n    border-bottom: 1px solid var(--light-border) !important;\n  }\n  \n  tr.el-table__row:nth-child(even) td {\n    background-color: var(--background-stripe-even) !important;\n  }\n  \n  tr.highlighted-row td {\n    background-color: var(--selected-row-background) !important;\n  }\n  \n  .el-table__empty-block {\n    background-color: var(--background-card) !important;\n  }\n\n  .table-header-row th {\n    background-color: var(--background-card) !important;\n    border-bottom: 1px solid var(--table-header-border) !important;\n  }\n}\n\n:deep(.custom-border-table) {\n  &::before {\n    background-color: transparent !important;\n    height: 0 !important;\n  }\n  \n  .el-table__header tr th {\n    border-bottom: 1px solid var(--divider-color) !important;\n  }\n  \n  .el-table__cell {\n    border-bottom: 1px solid var(--light-border) !important;\n  }\n}\n\n:deep(.no-header-line) {\n  &::before, &::after {\n    display: none !important;\n    height: 0 !important;\n    background-color: transparent !important;\n  }\n  \n  .el-table__header-wrapper {\n    &::before, &::after {\n      display: none !important;\n      height: 0 !important;\n      background-color: transparent !important;\n    }\n    \n    border-bottom: 1px solid var(--divider-color) !important;\n  }\n}\n\n:deep(.dark-input) {\n  .el-input__inner {\n    background-color: var(--date-input-bg) !important;\n    color: var(--text-color) !important;\n  }\n}\n\n:deep(.dark-date-input) {\n  .el-input__inner {\n    background-color: var(--date-input-bg) !important;\n    color: var(--text-color) !important;\n  }\n  input {\n    background-color: var(--date-input-bg) !important;\n    color: var(--text-color) !important;\n  }\n  .el-input__prefix {\n    background-color: var(--date-input-bg) !important;\n  }\n}\n\n:deep(.dark-select) {\n  .el-input__inner {\n    background-color: var(--date-input-bg) !important;\n    color: var(--text-color) !important;\n  }\n}\n\n:deep(.dark-date-picker) {\n  background-color: var(--datepicker-background) !important;\n}\n\n:deep(.dark-select-dropdown) {\n  background-color: var(--select-dropdown-bg) !important;\n  \n  .el-select-dropdown__item {\n    color: var(--text-color) !important;\n  }\n  \n  .el-select-dropdown__item.hover {\n    background-color: var(--hover-color) !important;\n  }\n}\n\n@media (max-width: 768px) {\n  .page-title {\n    font-size: 1.3rem;\n  }\n  \n  .filter-item {\n    margin-bottom: 8px;\n  }\n  \n  .log-data-container {\n    padding: 10px;\n  }\n}\n</style> "],"mappings":"AA6JA,OAAOA,GAAE,MAAO,iBAAgB;AAEhC,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE;QACPC,SAAS,EAAEC,IAAI,CAACC,GAAG,CAAC,IAAI,IAAI,EAAC,GAAI,EAAC,GAAI,EAAC,GAAI,IA