{"ast":null,"code":"import api from '../services/api';\nimport { use } from 'echarts/core';\nimport { CanvasRenderer } from 'echarts/renderers';\nimport { BarChart, PieChart } from 'echarts/charts';\nimport { TitleComponent, TooltipComponent, LegendComponent, GridComponent } from 'echarts/components';\nimport VChart from 'vue-echarts';\nuse([CanvasRenderer, BarChart, PieChart, TitleComponent, TooltipComponent, LegendComponent, GridComponent]);\nexport default {\n  name: 'LogDataView',\n  components: {\n    VChart\n  },\n  data() {\n    return {\n      filters: {\n        startTime: Date.now() - 7 * 24 * 60 * 60 * 1000,\n        // 默认7天前\n        endTime: Date.now(),\n        messageType: '',\n        userId: ''\n      },\n      logData: {\n        action_type_count: {\n          socket_disconnected_count: 0,\n          launch_count: 0,\n          enter_room_count: 0,\n          send_message_count: 0,\n          send_success_count: 0,\n          send_fail_count: 0\n        },\n        avg_socket_time: {\n          average_response_time: 0\n        },\n        user_count: 0,\n        message_send_avg_time: 0,\n        send_to_sync_avg: 0\n      }\n    };\n  },\n  computed: {\n    actionTypeData() {\n      return [{\n        name: '启动次数',\n        value: this.logData.action_type_count?.launch_count || 0,\n        key: 'launch_count'\n      }, {\n        name: 'socket断开次数',\n        value: this.logData.action_type_count?.socket_disconnected_count || 0,\n        key: 'socket_disconnected_count'\n      }, {\n        name: '进入房间次数',\n        value: this.logData.action_type_count?.enter_room_count || 0,\n        key: 'enter_room_count'\n      }, {\n        name: '发消息次数',\n        value: this.logData.action_type_count?.send_message_count || 0,\n        key: 'send_message_count'\n      }, {\n        name: '消息发送成功次数',\n        value: this.logData.action_type_count?.send_success_count || 0,\n        key: 'send_success_count'\n      }, {\n        name: '消息发送失败次数',\n        value: this.logData.action_type_count?.send_fail_count || 0,\n        key: 'send_fail_count'\n      }, {\n        name: '用户数',\n        value: this.logData.user_count || 0,\n        key: 'user_count'\n      }];\n    },\n    timeData() {\n      return [{\n        name: 'socket链接时长',\n        value: this.logData.avg_socket_time?.average_response_time || 0,\n        key: 'avg_socket_time'\n      }, {\n        name: '发消息耗时',\n        value: this.logData.message_send_avg_time || 0,\n        key: 'avg_sendmessage_time'\n      }, {\n        name: 'sync回消息耗时',\n        value: this.logData.send_to_sync_avg || 0,\n        key: 'send_to_sync'\n      }];\n    },\n    actionChartOption() {\n      return {\n        backgroundColor: 'transparent',\n        tooltip: {\n          trigger: 'item'\n        },\n        legend: {\n          top: '5%',\n          left: 'center',\n          textStyle: {\n            color: '#f0f0f0'\n          }\n        },\n        series: [{\n          name: '操作次数',\n          type: 'pie',\n          radius: ['40%', '70%'],\n          avoidLabelOverlap: false,\n          itemStyle: {\n            borderRadius: 10,\n            borderColor: '#252525',\n            borderWidth: 2\n          },\n          label: {\n            show: false,\n            position: 'center'\n          },\n          emphasis: {\n            label: {\n              show: true,\n              fontSize: '18',\n              fontWeight: 'bold',\n              color: '#f0f0f0'\n            }\n          },\n          labelLine: {\n            show: false\n          },\n          data: this.actionTypeData.map(item => ({\n            value: item.value,\n            name: item.name\n          }))\n        }]\n      };\n    },\n    timeChartOption() {\n      return {\n        backgroundColor: 'transparent',\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'shadow'\n          }\n        },\n        grid: {\n          left: '3%',\n          right: '4%',\n          bottom: '3%',\n          containLabel: true\n        },\n        xAxis: [{\n          type: 'category',\n          data: this.timeData.map(item => item.name),\n          axisTick: {\n            alignWithLabel: true\n          },\n          axisLabel: {\n            color: '#f0f0f0'\n          },\n          axisLine: {\n            lineStyle: {\n              color: '#f0f0f0'\n            }\n          }\n        }],\n        yAxis: [{\n          type: 'value',\n          axisLabel: {\n            color: '#f0f0f0'\n          },\n          axisLine: {\n            lineStyle: {\n              color: '#f0f0f0'\n            }\n          },\n          splitLine: {\n            lineStyle: {\n              color: 'rgba(240, 240, 240, 0.1)'\n            }\n          }\n        }],\n        series: [{\n          name: '耗时(ms)',\n          type: 'bar',\n          barWidth: '60%',\n          data: this.timeData.map(item => item.value),\n          itemStyle: {\n            color: '#42b983'\n          }\n        }]\n      };\n    }\n  },\n  mounted() {\n    this.fetchData();\n  },\n  methods: {\n    async fetchData() {\n      try {\n        const response = await api.getLogSummary(this.filters.startTime, this.filters.endTime, this.filters.messageType, this.filters.userId);\n        this.logData = response.data;\n      } catch (error) {\n        console.error('获取日志数据失败:', error);\n        this.$message.error('获取数据失败，请稍后重试');\n      }\n    }\n  }\n};","map":{"version":3,"names":["api","use","CanvasRenderer","BarChart","PieChart","TitleComponent","TooltipComponent","LegendComponent","GridComponent","VChart","name","components","data","filters","startTime","Date","now","endTime","messageType","userId","logData","action_type_count","socket_disconnected_count","launch_count","enter_room_count","send_message_count","send_success_count","send_fail_count","avg_socket_time","average_response_time","user_count","message_send_avg_time","send_to_sync_avg","computed","actionTypeData","value","key","timeData","actionChartOption","backgroundColor","tooltip","trigger","legend","top","left","textStyle","color","series","type","radius","avoidLabelOverlap","itemStyle","borderRadius","borderColor","borderWidth","label","show","position","emphasis","fontSize","fontWeight","labelLine","map","item","timeChartOption","axisPointer","grid","right","bottom","containLabel","xAxis","axisTick","alignWithLabel","axisLabel","axisLine","lineStyle","yAxis","splitLine","barWidth","mounted","fetchData","methods","response","getLogSummary","error","console","$message"],"sources":["/Users/apple/ai_completion/trace/src/views/LogDataView.vue"],"sourcesContent":["<template>\n  <div class=\"log-data-container\">\n    <h1 class=\"page-title\">日志数据中心</h1>\n    \n    <el-card class=\"filter-card\">\n      <div class=\"filter-container\">\n        <div class=\"filter-item\">\n          <span class=\"filter-label\">开始时间：</span>\n          <el-date-picker\n            v-model=\"filters.startTime\"\n            type=\"datetime\"\n            placeholder=\"选择开始时间\"\n            format=\"YYYY-MM-DD HH:mm:ss\"\n            value-format=\"x\"\n          />\n        </div>\n        \n        <div class=\"filter-item\">\n          <span class=\"filter-label\">结束时间：</span>\n          <el-date-picker\n            v-model=\"filters.endTime\"\n            type=\"datetime\"\n            placeholder=\"选择结束时间\"\n            format=\"YYYY-MM-DD HH:mm:ss\"\n            value-format=\"x\"\n          />\n        </div>\n        \n        <div class=\"filter-item\">\n          <span class=\"filter-label\">消息类型：</span>\n          <el-select\n            v-model=\"filters.messageType\"\n            placeholder=\"请选择消息类型\"\n            clearable\n          >\n            <el-option label=\"文本消息\" value=\"m.text\" />\n            <el-option label=\"图片消息\" value=\"m.image\" />\n            <el-option label=\"视频消息\" value=\"m.video\" />\n            <el-option label=\"语音消息\" value=\"m.voice\" />\n            <el-option label=\"文件消息\" value=\"m.file\" />\n          </el-select>\n        </div>\n        \n        <div class=\"filter-item\">\n          <span class=\"filter-label\">用户ID：</span>\n          <el-input\n            v-model=\"filters.userId\"\n            placeholder=\"请输入用户ID\"\n            clearable\n          />\n        </div>\n        \n        <el-button type=\"primary\" @click=\"fetchData\">查询</el-button>\n      </div>\n    </el-card>\n    \n    <div class=\"data-display-section\">\n      <el-row :gutter=\"20\">\n        <el-col :span=\"8\">\n          <el-card class=\"data-card\">\n            <template #header>\n              <div class=\"card-header\">\n                <h3>用户数量</h3>\n              </div>\n            </template>\n            <div class=\"data-value\">{{ logData.user_count || 0 }}</div>\n          </el-card>\n        </el-col>\n        \n        <el-col :span=\"8\">\n          <el-card class=\"data-card\">\n            <template #header>\n              <div class=\"card-header\">\n                <h3>平均消息发送耗时</h3>\n              </div>\n            </template>\n            <div class=\"data-value\">{{ logData.message_send_avg_time || 0 }} ms</div>\n          </el-card>\n        </el-col>\n        \n        <el-col :span=\"8\">\n          <el-card class=\"data-card\">\n            <template #header>\n              <div class=\"card-header\">\n                <h3>平均Socket响应时间</h3>\n              </div>\n            </template>\n            <div class=\"data-value\">{{ logData.avg_socket_time?.average_response_time || 0 }} ms</div>\n          </el-card>\n        </el-col>\n      </el-row>\n      \n      <!-- 新增图表展示 -->\n      <el-card class=\"chart-card\">\n        <template #header>\n          <div class=\"card-header\">\n            <h3>操作统计图表</h3>\n          </div>\n        </template>\n        <v-chart class=\"chart\" :option=\"actionChartOption\" />\n      </el-card>\n      \n      <el-card class=\"chart-card\">\n        <template #header>\n          <div class=\"card-header\">\n            <h3>耗时统计图表</h3>\n          </div>\n        </template>\n        <v-chart class=\"chart\" :option=\"timeChartOption\" />\n      </el-card>\n      \n      <el-card class=\"stats-table-card\">\n        <template #header>\n          <div class=\"card-header\">\n            <h3>操作统计</h3>\n          </div>\n        </template>\n        <el-table :data=\"actionTypeData\" stripe style=\"width: 100%\">\n          <el-table-column prop=\"name\" label=\"事件\" />\n          <el-table-column prop=\"value\" label=\"数值\" width=\"180\" />\n          <el-table-column prop=\"key\" label=\"字段\" />\n        </el-table>\n      </el-card>\n      \n      <el-card class=\"stats-table-card\">\n        <template #header>\n          <div class=\"card-header\">\n            <h3>耗时统计</h3>\n          </div>\n        </template>\n        <el-table :data=\"timeData\" stripe style=\"width: 100%\">\n          <el-table-column prop=\"name\" label=\"事件\" />\n          <el-table-column prop=\"value\" label=\"数值 (ms)\" width=\"180\" />\n          <el-table-column prop=\"key\" label=\"字段\" />\n        </el-table>\n      </el-card>\n    </div>\n  </div>\n</template>\n\n<script>\nimport api from '../services/api'\nimport { use } from 'echarts/core'\nimport { CanvasRenderer } from 'echarts/renderers'\nimport { BarChart, PieChart } from 'echarts/charts'\nimport {\n  TitleComponent,\n  TooltipComponent,\n  LegendComponent,\n  GridComponent\n} from 'echarts/components'\nimport VChart from 'vue-echarts'\n\nuse([\n  CanvasRenderer,\n  BarChart,\n  PieChart,\n  TitleComponent,\n  TooltipComponent,\n  LegendComponent,\n  GridComponent\n])\n\nexport default {\n  name: 'LogDataView',\n  components: {\n    VChart\n  },\n  data() {\n    return {\n      filters: {\n        startTime: Date.now() - 7 * 24 * 60 * 60 * 1000, // 默认7天前\n        endTime: Date.now(),\n        messageType: '',\n        userId: ''\n      },\n      logData: {\n        action_type_count: {\n          socket_disconnected_count: 0,\n          launch_count: 0,\n          enter_room_count: 0,\n          send_message_count: 0,\n          send_success_count: 0,\n          send_fail_count: 0\n        },\n        avg_socket_time: {\n          average_response_time: 0\n        },\n        user_count: 0,\n        message_send_avg_time: 0,\n        send_to_sync_avg: 0\n      }\n    }\n  },\n  computed: {\n    actionTypeData() {\n      return [\n        { name: '启动次数', value: this.logData.action_type_count?.launch_count || 0, key: 'launch_count' },\n        { name: 'socket断开次数', value: this.logData.action_type_count?.socket_disconnected_count || 0, key: 'socket_disconnected_count' },\n        { name: '进入房间次数', value: this.logData.action_type_count?.enter_room_count || 0, key: 'enter_room_count' },\n        { name: '发消息次数', value: this.logData.action_type_count?.send_message_count || 0, key: 'send_message_count' },\n        { name: '消息发送成功次数', value: this.logData.action_type_count?.send_success_count || 0, key: 'send_success_count' },\n        { name: '消息发送失败次数', value: this.logData.action_type_count?.send_fail_count || 0, key: 'send_fail_count' },\n        { name: '用户数', value: this.logData.user_count || 0, key: 'user_count' }\n      ]\n    },\n    timeData() {\n      return [\n        { name: 'socket链接时长', value: this.logData.avg_socket_time?.average_response_time || 0, key: 'avg_socket_time' },\n        { name: '发消息耗时', value: this.logData.message_send_avg_time || 0, key: 'avg_sendmessage_time' },\n        { name: 'sync回消息耗时', value: this.logData.send_to_sync_avg || 0, key: 'send_to_sync' }\n      ]\n    },\n    actionChartOption() {\n      return {\n        backgroundColor: 'transparent',\n        tooltip: {\n          trigger: 'item'\n        },\n        legend: {\n          top: '5%',\n          left: 'center',\n          textStyle: {\n            color: '#f0f0f0'\n          }\n        },\n        series: [\n          {\n            name: '操作次数',\n            type: 'pie',\n            radius: ['40%', '70%'],\n            avoidLabelOverlap: false,\n            itemStyle: {\n              borderRadius: 10,\n              borderColor: '#252525',\n              borderWidth: 2\n            },\n            label: {\n              show: false,\n              position: 'center'\n            },\n            emphasis: {\n              label: {\n                show: true,\n                fontSize: '18',\n                fontWeight: 'bold',\n                color: '#f0f0f0'\n              }\n            },\n            labelLine: {\n              show: false\n            },\n            data: this.actionTypeData.map(item => ({\n              value: item.value,\n              name: item.name\n            }))\n          }\n        ]\n      }\n    },\n    timeChartOption() {\n      return {\n        backgroundColor: 'transparent',\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'shadow'\n          }\n        },\n        grid: {\n          left: '3%',\n          right: '4%',\n          bottom: '3%',\n          containLabel: true\n        },\n        xAxis: [\n          {\n            type: 'category',\n            data: this.timeData.map(item => item.name),\n            axisTick: {\n              alignWithLabel: true\n            },\n            axisLabel: {\n              color: '#f0f0f0'\n            },\n            axisLine: {\n              lineStyle: {\n                color: '#f0f0f0'\n              }\n            }\n          }\n        ],\n        yAxis: [\n          {\n            type: 'value',\n            axisLabel: {\n              color: '#f0f0f0'\n            },\n            axisLine: {\n              lineStyle: {\n                color: '#f0f0f0'\n              }\n            },\n            splitLine: {\n              lineStyle: {\n                color: 'rgba(240, 240, 240, 0.1)'\n              }\n            }\n          }\n        ],\n        series: [\n          {\n            name: '耗时(ms)',\n            type: 'bar',\n            barWidth: '60%',\n            data: this.timeData.map(item => item.value),\n            itemStyle: {\n              color: '#42b983'\n            }\n          }\n        ]\n      }\n    }\n  },\n  mounted() {\n    this.fetchData()\n  },\n  methods: {\n    async fetchData() {\n      try {\n        const response = await api.getLogSummary(\n          this.filters.startTime,\n          this.filters.endTime,\n          this.filters.messageType,\n          this.filters.userId\n        )\n        this.logData = response.data\n      } catch (error) {\n        console.error('获取日志数据失败:', error)\n        this.$message.error('获取数据失败，请稍后重试')\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.log-data-container {\n  padding: 20px;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.page-title {\n  color: var(--text-color);\n  margin-bottom: 20px;\n  text-align: center;\n}\n\n.filter-card {\n  margin-bottom: 30px;\n}\n\n.filter-container {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 15px;\n  align-items: center;\n}\n\n.filter-item {\n  display: flex;\n  align-items: center;\n  margin-right: 10px;\n}\n\n.filter-label {\n  margin-right: 8px;\n  white-space: nowrap;\n}\n\n.data-display-section {\n  margin-top: 20px;\n}\n\n.data-card {\n  height: 180px;\n  margin-bottom: 20px;\n  text-align: center;\n  \n  .data-value {\n    font-size: 42px;\n    font-weight: bold;\n    color: var(--secondary-color);\n    margin-top: 25px;\n  }\n}\n\n.chart-card {\n  margin-bottom: 20px;\n  \n  .chart {\n    height: 400px;\n    width: 100%;\n  }\n}\n\n.stats-table-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  \n  h3 {\n    margin: 0;\n    color: var(--text-color);\n  }\n}\n\n@media (max-width: 768px) {\n  .filter-container {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n  \n  .filter-item {\n    margin-botto